# Copy to api/.env and fill in AWS creds to enable Bedrock.
# docker-compose loads this file into the api container (and overrides
# DATABASE_URL / WEB_ORIGIN / AUTH_SHARED_SECRET with its network values).
# For local `uvicorn` runs, pydantic-settings reads it directly.
#
# Every value below is optional — the defaults shown match app/config.py.
# Uncommented lines are the ones you're most likely to set.

# --- LLM provider: bedrock | anthropic | mock | auto (default) ---
# auto = Bedrock if AWS creds resolve, else Anthropic if a key is set, else mock.
# Set to `anthropic` to use the Claude API even on a machine that has AWS creds.
LLM_PROVIDER=auto
# Legacy explicit override, honored only when LLM_PROVIDER is unset/auto.
# Prefer LLM_PROVIDER above.
# USE_BEDROCK=true

# --- Chat models: LOGICAL ids, resolved per provider by app.model_catalog ---
# Set these two logical ids and the catalog maps each to the active provider's
# concrete model string. Known ids: sonnet-4.5, haiku-4.5 (matching is case/
# punctuation-insensitive, e.g. "Sonnet45"). An unknown id falls back to that
# provider's default model (and says so in the logs).
# PARENT_MODEL=haiku-4.5     # parent chat agent (fast/cheap)
# CHAT_MODEL=sonnet-4.5      # operator authoring / handbook extraction (stronger)

# --- AWS Bedrock: fill these to use the real agents on Bedrock ---
# Creds also resolve via the standard boto3 chain (~/.aws, SSO, instance role).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Chat models are set above (PARENT_MODEL / CHAT_MODEL). This is only the Titan
# embedding model id, used on the Titan/bedrock embedding path:
# BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Anthropic Claude API: set the key and LLM_PROVIDER=anthropic to use it ---
# NOTE: Anthropic has no embeddings API. Pair it with Voyage AI embeddings (see
# EMBEDDINGS_PROVIDER below) for real semantic search; otherwise this path falls
# back to the offline mock embedder and you should run retrieval FTS-only.
ANTHROPIC_API_KEY=
# (Chat model choice is provider-agnostic now — set PARENT_MODEL / CHAT_MODEL
# above; the catalog maps them to the Anthropic model ids automatically.)

# --- Retrieval ---
# Which retrieval backend the agent reads through (Retriever interface).
# RETRIEVER=pgvector
# Semantic (vector) search. Set false to rank on Postgres full-text search only
# (no embeddings needed at all). After switching embedder/provider, run
# `uv run python -m app.reembed` so stored vectors match query vectors.
EMBEDDINGS_ENABLED=true
# Embedding vector dimensions (must match the stored vectors / embedder output).
# EMBEDDING_DIMS=1024
# Which embedder: voyage | titan | mock | auto (default). auto = Voyage if
# VOYAGE_API_KEY is set, else Titan in bedrock mode, else the offline mock.
# Voyage is independent of the chat provider — it's how the Anthropic/Claude path
# gets real vectors. After switching, run `uv run python -m app.reembed`.
# EMBEDDINGS_PROVIDER=auto
# Voyage AI (voyageai). Models default to 1024 dims — matches EMBEDDING_DIMS and
# the pgvector column, so it's a dimension drop-in. voyage-4* include 200M free tokens.
VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-3.5
# Give the parent agent knowledge-graph tools (search_graph/get_entity/
# expand_neighbors) on top of the always-injected subgraph. Set false to rely
# solely on the injected subgraph.
# KG_TOOLS_ENABLED=true
# Shape of the auto-injected subgraph (retrieve_subgraph). Defaults shown:
# RETRIEVAL_K=5                 # seed hits from hybrid search
# RETRIEVAL_EXPAND_TOP=3        # how many top hits to expand from
# RETRIEVAL_HOPS=1              # relationship hops to walk
# RETRIEVAL_MAX_ENTITIES=25     # safety cap on total injected entities

# --- Chat ---
# Short-term memory: prior turns of the current session fed to the parent agent
# so it can resolve follow-ups ("what about fever?"). 0 = stateless single-turn.
# CHAT_MEMORY_TURNS=10

# --- Used only for local (non-docker) runs; docker-compose overrides these ---
# DATABASE_URL also accepts the `postgres://` / `postgresql://` form that managed
# providers (Railway, Heroku) hand out — it's rewritten to the psycopg driver.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/frontdesk
WEB_ORIGIN=http://localhost:3000
AUTH_SHARED_SECRET=dev-shared-secret-change-me

# --- Hosted deploy (e.g. Railway) — see DEPLOY.md ---
# The server binds $PORT if set (Railway injects it), else 8000.
# First-boot seeding: "" = off (default), "demo" = full demo, "fresh" = scaffold
# only. Runs ONLY when the DB has no users yet, so it never wipes live data.
# SEED_ON_START=demo
