# Copy to api/.env and fill in AWS creds to enable Bedrock.
# docker-compose loads this file into the api container (and overrides
# DATABASE_URL / WEB_ORIGIN / AUTH_SHARED_SECRET with its network values).
# For local `uvicorn` runs, pydantic-settings reads it directly.

# --- LLM provider: bedrock | anthropic | mock | auto (default) ---
# auto = Bedrock if AWS creds resolve, else Anthropic if a key is set, else mock.
# Set to `anthropic` to use the Claude API even on a machine that has AWS creds.
LLM_PROVIDER=auto

# --- AWS Bedrock: fill these to use the real agents on Bedrock ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Anthropic Claude API: set the key and LLM_PROVIDER=anthropic to use it ---
# NOTE: Anthropic has no embeddings API, so this path uses the offline mock
# embedder. For meaningful semantic search, seed/ingest under this same mode so
# the stored vectors match (a KB embedded with Titan must be re-embedded).
ANTHROPIC_API_KEY=
# Optional model overrides (defaults shown):
# ANTHROPIC_PARENT_MODEL=claude-haiku-4-5
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# --- Used only for local (non-docker) runs; docker-compose overrides these ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/frontdesk
WEB_ORIGIN=http://localhost:3000
AUTH_SHARED_SECRET=dev-shared-secret-change-me
