# Copy to api/.env for local dev (docker-compose injects its own values).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/frontdesk
WEB_ORIGIN=http://localhost:3000
AUTH_SHARED_SECRET=dev-shared-secret-change-me

# AWS Bedrock — leave blank to run with the mock LLM fallback.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
